<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #10b981 0%, #059669 100%); margin: 0;
      padding: 40px 20px; min-height: 100vh; } .container { max-width: 600px;
      margin: 0 auto; background: white; border-radius: 16px; box-shadow: 0 20px
      40px rgba(0, 0, 0, 0.1); overflow: hidden; } .header { background:
      linear-gradient(135deg, #10b981 0%, #059669 100%); padding: 40px 30px;
      text-align: center; } .header h1 { color: white; font-size: 28px;
      font-weight: 600; margin: 0; letter-spacing: -0.5px; } .content { padding:
      50px 40px; text-align: center; }
      
       .icon { width: 80px; height: 80px;
  
      border-radius: 50%; margin: 0 auto 30px; display: flex;
      justify-content: center !important;
      align-items: center !important;
       font-size: 36px; 
       background-color: #ffff;
        }
      
      .icon img {
        width: 80px;
        height: 80px;
      }
       .message
      { font-size: 18px; color: #4b5563; line-height: 1.6; margin-bottom: 40px;
      } .order-details { background: #f8fafc; border: 2px solid #e2e8f0;
      border-radius: 12px; padding: 30px; margin: 30px 0; text-align: left; }
      .detail-row { display: flex; justify-content: space-between; align-items:
      center; padding: 12px 0; border-bottom: 1px solid #e2e8f0; }
      .detail-row:last-child { border-bottom: none; font-weight: 600; font-size:
      18px; color: #059669; } .detail-label { font-weight: 500; color: #6b7280; margin-right: 20px;
      } .detail-value { font-weight: 600; color: #1e293b; } .amount { font-size:
      24px; color: #059669; } .success-badge { background: #dcfce7; color:
      #166534; padding: 8px 16px; border-radius: 20px; font-size: 14px;
      font-weight: 600; display: inline-block; margin: 20px 0; } .footer {
      background: #f8fafc; padding: 30px; text-align: center; border-top: 1px
      solid #e2e8f0; } .footer-text { font-size: 14px; color: #6b7280; margin:
      0; } @media (max-width: 640px) { body { padding: 20px 10px; } .container {
      border-radius: 12px; } .header { padding: 30px 20px; } .header h1 {
      font-size: 24px; } .content { padding: 40px 20px; } .detail-row {
      flex-direction: column; align-items: flex-start; gap: 4px; } .icon {
      width: 60px; height: 60px; font-size: 28px; } .amount { font-size: 20px; }
      }
    </style>
    <title>{{title}}</title>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>{{title}}</h1>
      </div>

      <div class="content">
        <div class="icon">
          <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/3/3b/Eo_circle_green_checkmark.svg/1200px-Eo_circle_green_checkmark.svg.png" alt="icon" />
        </div>

        <p class="message">
          Xin chào
          <strong>{{customerName}}</strong>,<br />
          {{message}}
        </p>

        <div class="success-badge">
          ✨ Giao dịch hoàn tất
        </div>

        <div class="order-details">
          <div class="detail-row">
            <span class="detail-label">Mã đơn hàng: </span>
            <span class="detail-value"> {{code}}</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Khách hàng: </span>
            <span class="detail-value"> {{customerName}}</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Ngày thanh toán: </span>
            <span class="detail-value"> {{paymentDate}}</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Tổng tiền:  </span>
            <span class="detail-value amount"> {{amount}}</span>
          </div>
        </div>

        <!-- Updated message for next steps -->
        <p class="message">
          Chúng tôi sẽ xử lý đơn hàng của bạn trong thời gian sớm nhất.<br />
          Bạn sẽ nhận được email thông báo khi đơn hàng được giao.
        </p>
      </div>

      <div class="footer">
        <p class="footer-text">
          Cảm ơn bạn đã tin tưởng và sử dụng dịch vụ của chúng tôi!
        </p>
      </div>
    </div>
  </body>
</html>